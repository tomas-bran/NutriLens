# NutriLens — variables de entorno
# Copiar este archivo a `.env.local` (NO se commitea) y completar los valores.
# Las claves marcadas como REQUIRED son obligatorias para correr el MVP.

# ---------------------------------------------------------------------------
# IA — Azure AI Foundry / Azure OpenAI
# ---------------------------------------------------------------------------
# Selector de provider. Valores:
#   - "mock"  → no llama a Azure, usa fixtures locales (default en dev/CI)
#   - "azure" → llama a Azure AI Foundry (default en demo/prod)
IA_PROVIDER=mock

# Endpoint del recurso de Azure OpenAI dentro del Foundry project.
# Formato: https://<nombre-del-recurso>.openai.azure.com
AZURE_OPENAI_ENDPOINT=

# API key (KEY 1 desde Azure AI Foundry → tu project → "Models + endpoints").
# REQUIRED si IA_PROVIDER=azure
AZURE_OPENAI_API_KEY=

# Versión del API. Fija una estable.
AZURE_OPENAI_API_VERSION=2024-10-21

# Nombres de DEPLOYMENT (no de modelo). Son los que pusiste al desplegar
# cada modelo dentro del Foundry project.
# REQUIRED si IA_PROVIDER=azure
AZURE_OPENAI_DEPLOYMENT_GPT4O=nutrilens-gpt4o
AZURE_OPENAI_DEPLOYMENT_GPT4O_MINI=nutrilens-gpt4o-mini

# ---------------------------------------------------------------------------
# IA — Document Intelligence (OPCIONAL)
# ---------------------------------------------------------------------------
# Solo si necesitamos OCR adicional para PDFs problemáticos.
# Dejar vacío para que el sistema use GPT-4o directo sobre el PDF.
AZURE_DOCINTEL_ENDPOINT=
AZURE_DOCINTEL_KEY=

# ---------------------------------------------------------------------------
# Base de datos
# ---------------------------------------------------------------------------
# En dev usamos SQLite (default si esta variable está vacía).
# En demo apuntar a Azure Database for PostgreSQL.
# Ejemplo: postgresql://user:pass@host:5432/nutrilens?sslmode=require
DATABASE_URL=

# ---------------------------------------------------------------------------
# Storage de imágenes
# ---------------------------------------------------------------------------
# En dev usamos filesystem local (carpeta /uploads, gitignored).
# En demo usar Azure Blob Storage.
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=nutrilens-uploads

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
# URL base de la app, usada para construir links absolutos.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Nivel de log. Valores: debug, info, warn, error
LOG_LEVEL=info
