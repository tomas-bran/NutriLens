# NutriLens — variables de entorno
# Copiar este archivo a `.env.local` (NO se commitea) y completar los valores.
# Las claves marcadas como REQUIRED son obligatorias para correr el MVP.

# ---------------------------------------------------------------------------
# IA — selector de provider
# ---------------------------------------------------------------------------
# Valores:
#   - "mock"          → no llama a Azure, usa fixtures locales (default en dev/CI)
#   - "foundry"       → Azure AI Foundry (modelos Phi-4 via endpoint OpenAI-compatible)
#   - "azure-openai"  → Azure OpenAI (gpt-4o), cuando se apruebe el acceso
IA_PROVIDER=mock

# ---------------------------------------------------------------------------
# IA — Azure AI Foundry (Phi-4)
# ---------------------------------------------------------------------------
# Azure AI Foundry expone un endpoint OpenAI-compatible UNIFICADO para todos
# los modelos del resource. Un solo endpoint + key; los modelos se distinguen
# por el campo `model` en cada request.
#
# Para obtener estos valores:
#   Portal → Azure AI Foundry → tu project → Models + endpoints
#   - Click en un deployment cualquiera
#   - "View code" → muestra el baseURL (termina en /openai/v1) y el deployment name

# Endpoint base. Formato:
#   https://<resource>.services.ai.azure.com/openai/v1
# REQUIRED si IA_PROVIDER=foundry
AZURE_AI_FOUNDRY_ENDPOINT=

# API key del resource (NO de un deployment).
# REQUIRED si IA_PROVIDER=foundry
AZURE_AI_FOUNDRY_KEY=

# Nombres exactos de los deployments (case-sensitive, como aparecen en el portal).
# REQUIRED si IA_PROVIDER=foundry
AZURE_AI_FOUNDRY_MODEL_MULTIMODAL=Phi-4-multimodal-instruct
AZURE_AI_FOUNDRY_MODEL_MINI=Phi-4-mini-instruct

# ---------------------------------------------------------------------------
# IA — Azure OpenAI (gpt-4o) — UPGRADE FUTURO
# ---------------------------------------------------------------------------
# Completar y cambiar IA_PROVIDER=azure-openai cuando se apruebe el acceso a
# Azure OpenAI Service. Mismo SDK (openai), distinto baseURL y deployment names.
#
# Endpoint base. Formato:
#   https://<resource>.openai.azure.com/openai/v1
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_MODEL_GPT4O=
AZURE_OPENAI_MODEL_GPT4O_MINI=

# ---------------------------------------------------------------------------
# IA — Document Intelligence (OPCIONAL)
# ---------------------------------------------------------------------------
# Solo si necesitamos OCR adicional para PDFs problemáticos.
# Dejar vacío para que el sistema use el modelo multimodal directo sobre el PDF.
AZURE_DOCINTEL_ENDPOINT=
AZURE_DOCINTEL_KEY=

# ---------------------------------------------------------------------------
# Base de datos
# ---------------------------------------------------------------------------
# En dev usamos SQLite (default si esta variable está vacía).
# En demo apuntar a Azure Database for PostgreSQL.
# Ejemplo: postgresql://user:pass@host:5432/nutrilens?sslmode=require
DATABASE_URL=

# ---------------------------------------------------------------------------
# Storage de imágenes
# ---------------------------------------------------------------------------
# En dev usamos filesystem local (carpeta /uploads, gitignored).
# En demo usar Azure Blob Storage.
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=nutrilens-uploads

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
# URL base de la app, usada para construir links absolutos.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Nivel de log. Valores: debug, info, warn, error
LOG_LEVEL=info
