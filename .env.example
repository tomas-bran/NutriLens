# NutriLens — environment variables template
# Copy this file to `.env.local` (NOT committed) and fill in the values.
# Required keys are marked as REQUIRED.

# ---------------------------------------------------------------------------
# AI — provider selector
# ---------------------------------------------------------------------------
# Values:
#   - "mock"          → no calls, uses local fixtures (default for dev/CI)
#   - "foundry"       → Azure AI Foundry (Phi-4 via OpenAI-compatible endpoint)
#   - "azure-openai"  → Azure OpenAI endpoint (AZURE_OPENAI_* vars)
#   - "openai"        → OpenAI API directa (api.openai.com, OPENAI_API_KEY)
IA_PROVIDER=mock

# ---------------------------------------------------------------------------
# AI — Azure AI Foundry (Phi-4)
# ---------------------------------------------------------------------------
# Azure AI Foundry exposes a UNIFIED OpenAI-compatible endpoint for all models
# in the resource. Single endpoint + key; models are selected via the `model`
# field in each request.
#
# How to get these values:
#   Portal → Azure AI Foundry → your project → Models + endpoints
#   - Click any deployment → "View code" → shows baseURL (ends in /openai/v1)
#     and the deployment name.

# Base endpoint. Format: https://<resource>.services.ai.azure.com/openai/v1
# REQUIRED if IA_PROVIDER=foundry
AZURE_AI_FOUNDRY_ENDPOINT=

# Resource API key (NOT a deployment-specific key).
# REQUIRED if IA_PROVIDER=foundry
AZURE_AI_FOUNDRY_KEY=

# Exact deployment names (case-sensitive, as shown in the portal).
# REQUIRED if IA_PROVIDER=foundry
AZURE_AI_FOUNDRY_MODEL_MULTIMODAL=Phi-4-multimodal-instruct
AZURE_AI_FOUNDRY_MODEL_MINI=Phi-4-mini-instruct

# ---------------------------------------------------------------------------
# AI — Azure OpenAI (gpt-5.1 / gpt-4o)
# ---------------------------------------------------------------------------
# Activá con `IA_PROVIDER=azure-openai`. Mismo SDK (openai), distinta baseURL.
#
# Expected base endpoint: https://<resource>.openai.azure.com/openai/v1
#  (o https://<resource>.services.ai.azure.com/api/projects/<proj>/openai/v1
#   para Azure AI Foundry como puerta de entrada a Azure OpenAI).
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=

# Modelo para calls multimodales (extract + classify de etiquetas).
# Ej: gpt-5.1, gpt-4o.
AZURE_OPENAI_MODEL_MULTIMODAL=

# Opcional: modelo text-only para explain/chat/intent. Si queda vacío,
# AzureOpenAIProvider reusa el multimodal (más caro pero menos config).
AZURE_OPENAI_MODEL_MINI=

# ---------------------------------------------------------------------------
# AI — Document Intelligence (OPTIONAL)
# ---------------------------------------------------------------------------
# Only needed if Phi-4-multimodal struggles with certain PDFs and we need
# a dedicated OCR fallback. Leave empty to skip Document Intelligence.
AZURE_DOCINTEL_ENDPOINT=
AZURE_DOCINTEL_KEY=

# ---------------------------------------------------------------------------
# Database — PostgreSQL
# ---------------------------------------------------------------------------
# Default for `docker compose` (service hostname = "db"):
#   postgresql://nutrilens:nutrilens@db:5432/nutrilens
# Default for running the app outside docker but DB inside (localhost):
#   postgresql://nutrilens:nutrilens@localhost:5432/nutrilens
DATABASE_URL=postgresql://nutrilens:nutrilens@localhost:5432/nutrilens

# Used by docker-compose to bootstrap the Postgres container.
POSTGRES_USER=nutrilens
POSTGRES_PASSWORD=nutrilens
POSTGRES_DB=nutrilens

# ---------------------------------------------------------------------------
# Image storage
# ---------------------------------------------------------------------------
# Dev: local filesystem (`/uploads`, gitignored).
# Demo: Azure Blob Storage.
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=nutrilens-uploads

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
# Base URL of the app, used to build absolute links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Log level. Values: debug, info, warn, error
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# AI — OpenAI directa (IA_PROVIDER=openai)
# ---------------------------------------------------------------------------
# API key de platform.openai.com
OPENAI_API_KEY=
# Modelo multimodal con visión (default: gpt-4o)
OPENAI_MODEL_MULTIMODAL=gpt-4o
# Modelo rápido/barato para texto (default: gpt-4o-mini)
OPENAI_MODEL_MINI=gpt-4o-mini

# ---------------------------------------------------------------------------
# Storage de imágenes (NL-102)
# ---------------------------------------------------------------------------
# Si está seteada, las imágenes analizadas van a Azure Blob (container privado,
# la app guarda una SAS URL de lectura). Vacía => LocalStorage (public/uploads).
AZURE_BLOB_CONNECTION_STRING=
# Container destino (default: uploads)
AZURE_BLOB_CONTAINER=
