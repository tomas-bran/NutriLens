# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/

# Node / Next.js (para cuando arranque el código)
node_modules/
.next/
out/
build/
dist/

# Variables de entorno con secrets (NUNCA commitearlas).
# .env.example si se commitea como template.
.env
.env.local
.env.*.local

# Uploads locales (imágenes subidas por usuarios en dev). Anclado al root
# para que no matchee subdirectorios `uploads/` que sí queremos commitear
# (ej. el dataset seed de US-38 vive en `public/uploads/seed/`).
/uploads/
public/uploads/*
!public/uploads/seed/
!public/uploads/seed/**
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# IDE / Editores
.idea/
.vscode/
*.swp
*.swo
*~

# Coverage / testing
coverage/
.nyc_output/
playwright-report/
test-results/
playwright/.cache/

# Prisma local DB
prisma/dev.db
prisma/dev.db-journal
test.db
test.db-journal

# Next typed routes & build outputs adicionales
.swc/
.turbo/
tsconfig.tsbuildinfo

# Husky tmp
.husky/_

# Evals — cached model responses (re-generated on demand, not committed)
evals/.cache/

# Misc
.cache/
.codex-runtime/
tmp/
temp/

# Artefactos locales del Playwright MCP (snapshots/console logs de debug)
.playwright-mcp/

# Permisos locales de Claude Code (por máquina, no del equipo)
.claude/settings.local.json
