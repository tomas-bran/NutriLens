# NutriLens mobile (Expo) — variables públicas. Copiá a `.env` y completá.
# Todo lo que empieza con EXPO_PUBLIC_ queda embebido en el bundle (no es secreto).

# Client IDs de Google (Google Cloud Console → Credentials → OAuth client IDs).
# Creá un client por plataforma. El backend debe permitir estos mismos IDs en
# MOBILE_GOOGLE_CLIENT_IDS.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Backend al que pega la app. Si se omite, usa la IP LAN de la PC que corre
# `expo start` (sirve si el teléfono está en la misma red). Para probar contra
# el deploy desde cualquier red, apuntá a Azure:
# EXPO_PUBLIC_API_BASE_URL=https://nutrilens-app.azurewebsites.net/api

# Dev sin Google: usa el usuario fijo del bypass (requiere E2E_AUTH_BYPASS=true
# en el backend). Nunca en builds reales.
# EXPO_PUBLIC_AUTH_DEV_BYPASS=true
